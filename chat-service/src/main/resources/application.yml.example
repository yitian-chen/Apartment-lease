server:
  port: 8082

spring:
  application:
    name: chat-service
  cloud:
    nacos:
      discovery:
        server-addr: 127.0.0.1:8848
        namespace: public
      config:
        import-check:
          enabled: false
  datasource:
    url: jdbc:mysql://127.0.0.1:3307/lease?useUnicode=true&characterEncoding=utf-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=GMT%2b8
    username: root
    password: # 数据库密码
  data:
    redis:
      host: localhost
      port: 6379
      database: 0

springdoc:
  api-docs:
    path: /chat-service-docs

# WebSocket配置
websocket:
  endpoint: /app/chat

mybatis-plus:
  mapper-locations: classpath*:/mapper/**/*.xml
